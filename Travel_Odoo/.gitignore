## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Bb]in/
[Oo]bj/
[Ll]og/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# ASP.NET Core
appsettings.Development.json
wwwroot/lib/
node_modules/

# Rider
.idea/

# VS Code
.vscode/

# Visual Studio cache/options directory
.vs/

# NUnit
TestResult.xml
nunit-*.xml

# MSTest
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NuGet
*.nupkg
packages/
!packages/build/
*.snupkg

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Publish output
publish/
*.publishsettings

# Azure
PublishScripts/

# IIS Express
iisexpress/
*.dbmdl

# SQL Server files
*.mdf
*.ldf

# Resharper
_ReSharper*/
*.ReSharper
*.DotSettings.user

# Logs
*.log

# OS generated files
.DS_Store
Thumbs.db

# Environment files
.env
.env.*

# Coverage results
coverage/
*.coverage
*.coveragexml

# Temporary files
*.tmp
*.temp

# JetBrains Rider
*.sln.iml

# Backup & package files
*.bak
*.zip
*.rar

# Entity Framework migrations snapshot backups
*MigrationsBackup*

# Generated files
Generated/